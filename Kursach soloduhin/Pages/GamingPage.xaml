<Page x:Class="Kursach_soloduhin.GamingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Готовые игровые ПК"
      Background="#101018">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="#101018">
        <StackPanel Margin="20,15,20,15">
            <Border CornerRadius="10" Padding="20" Background="#181830">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="Готовые игровые ПК" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,0,0,6" />
                        <TextBlock Text="Максимальная производительность для современных игр в разрешении 1080p и 1440p. Подберите систему под ваш стиль игры." Foreground="#CCCCCC" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Подобрать ПК" Padding="18,6" Margin="0,0,8,0" Background="#FF4B1F" Foreground="White" BorderBrush="Transparent" Cursor="Hand" />
                            <Button Content="Смотреть все сборки" Padding="16,6" Background="Transparent" BorderBrush="#FF4B1F" Foreground="#FF4B1F" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="8" Background="#202040" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Grid>
                            <TextBlock Text="ФОТО ИГРОВОГО ПК" Foreground="#666" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            <TextBlock Text="Популярные игровые сборки" Margin="0,20,0,10" Foreground="White" FontSize="20" FontWeight="SemiBold" />
            <UniformGrid Columns="3" Margin="0,0,0,10">
                <Border Margin="5" Padding="10" CornerRadius="8" Background="#151528" BorderBrush="#222" BorderThickness="1">
                    <StackPanel>
                        <Rectangle Height="100" RadiusX="6" RadiusY="6" Fill="#202040" />
                        <TextBlock Text="PC GAMER" Margin="0,10,0,2" Foreground="White" FontWeight="Bold" FontSize="14" />
                        <TextBlock Text="RTX 4060 • Ryzen 5 • 16 ГБ" Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="от 99 990 ₽" Margin="0,6,0,8" Foreground="#FF4B1F" FontSize="14" FontWeight="Bold" />
                        <Button Content="Купить" Padding="10,4" Background="#FF4B1F" Foreground="White" BorderBrush="Transparent" Cursor="Hand" />
                    </StackPanel>
                </Border>
                <Border Margin="5" Padding="10" CornerRadius="8" Background="#151528" BorderBrush="#222" BorderThickness="1">
                    <StackPanel>
                        <Rectangle Height="100" RadiusX="6" RadiusY="6" Fill="#202040" />
                        <TextBlock Text="PC PRO" Margin="0,10,0,2" Foreground="White" FontWeight="Bold" FontSize="14" />
                        <TextBlock Text="RTX 4070 SUPER • i7 • 32 ГБ" Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="от 149 990 ₽" Margin="0,6,0,8" Foreground="#FF4B1F" FontSize="14" FontWeight="Bold" />
                        <Button Content="Купить" Padding="10,4" Background="#FF4B1F" Foreground="White" BorderBrush="Transparent" Cursor="Hand" />
                    </StackPanel>
                </Border>
                <Border Margin="5" Padding="10" CornerRadius="8" Background="#151528" BorderBrush="#222" BorderThickness="1">
                    <StackPanel>
                        <Rectangle Height="100" RadiusX="6" RadiusY="6" Fill="#202040" />
                        <TextBlock Text="PC ULTRA" Margin="0,10,0,2" Foreground="White" FontWeight="Bold" FontSize="14" />
                        <TextBlock Text="RTX 4090 • i9 • 64 ГБ" Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Text="от 299 990 ₽" Margin="0,6,0,8" Foreground="#FF4B1F" FontSize="14" FontWeight="Bold" />
                        <Button Content="Купить" Padding="10,4" Background="#FF4B1F" Foreground="White" BorderBrush="Transparent" Cursor="Hand" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Page>

